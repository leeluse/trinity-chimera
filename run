#!/bin/bash
set -euo pipefail

# -------------------------------------------------------------------
# Core Paths / Runtime Knobs
# -------------------------------------------------------------------
PROJECT_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
export PATH="/usr/local/bin:/opt/homebrew/bin:$PATH"

COMMAND="${1:-}"
shift || true

CLIENT_DIR="${PROJECT_ROOT}/client"
RUN_DIR="${PROJECT_ROOT}/tmp/always_on"
FRONTEND_BOOTSTRAP_STATE="${RUN_DIR}/frontend_bootstrap.state"
JS_MANAGER="${JS_MANAGER:-auto}"
VERCEL_PROJECT_DIR="${VERCEL_PROJECT_DIR:-$CLIENT_DIR}"
VERCEL_BIN="${VERCEL_BIN:-vercel}"

mkdir -p "$RUN_DIR"

# -------------------------------------------------------------------
# Help / Usage
# -------------------------------------------------------------------
usage() {
  cat <<USAGE
Usage: ./run [client|front|dev|deploy|legacy]

Primary commands:
  client|front|dev    Start Next.js frontend (with lightweight bootstrap)
  deploy              Deploy frontend via Vercel (prod)

Compatibility:
  server|api|public|public-status|public-stop|tunnel|tunnel-stop|clean|test
                      Automatically delegated to scripts/run-legacy.sh
  legacy <args...>    Call legacy runner directly

Env:
  JS_MANAGER=auto|yarn|npm
  FORCE_BOOTSTRAP_FRONTEND=1
  VERCEL_PROJECT_DIR=/abs/path/to/project
  VERCEL_BIN=vercel
USAGE
}

# -------------------------------------------------------------------
# Version / Runtime Resolution Helpers
# -------------------------------------------------------------------
semver_gte() {
  local lhs="${1#v}" rhs="${2#v}"
  local l1 l2 l3 r1 r2 r3
  IFS='.' read -r l1 l2 l3 <<< "$lhs"
  IFS='.' read -r r1 r2 r3 <<< "$rhs"
  l1="${l1:-0}"; l2="${l2:-0}"; l3="${l3:-0}"
  r1="${r1:-0}"; r2="${r2:-0}"; r3="${r3:-0}"

  if ((10#$l1 > 10#$r1)); then return 0; fi
  if ((10#$l1 < 10#$r1)); then return 1; fi
  if ((10#$l2 > 10#$r2)); then return 0; fi
  if ((10#$l2 < 10#$r2)); then return 1; fi
  if ((10#$l3 >= 10#$r3)); then return 0; fi
  return 1
}

resolve_frontend_node_runtime() {
  local required_min_version="20.19.0"
  local current_node_version=""

  if command -v node >/dev/null 2>&1; then
    current_node_version="$(node -v 2>/dev/null | sed 's/^v//')"
    if [ -n "$current_node_version" ] && semver_gte "$current_node_version" "$required_min_version"; then
      return 0
    fi
  fi

  local candidate_bins=()
  local nvmrc_version="" nvmrc_major=""
  if [ -f "$CLIENT_DIR/.nvmrc" ]; then
    nvmrc_version="$(tr -d '[:space:]v' < "$CLIENT_DIR/.nvmrc")"
    nvmrc_major="${nvmrc_version%%.*}"
    if [ -n "$nvmrc_major" ]; then
      candidate_bins+=("/opt/homebrew/opt/node@${nvmrc_major}/bin")
      candidate_bins+=("/usr/local/opt/node@${nvmrc_major}/bin")
    fi
  fi

  candidate_bins+=("/opt/homebrew/opt/node@22/bin")
  candidate_bins+=("/usr/local/opt/node@22/bin")
  candidate_bins+=("/opt/homebrew/opt/node@20/bin")
  candidate_bins+=("/usr/local/opt/node@20/bin")

  local bin candidate_version
  for bin in "${candidate_bins[@]}"; do
    if [ ! -x "$bin/node" ]; then
      continue
    fi
    candidate_version="$("$bin/node" -v 2>/dev/null | sed 's/^v//')"
    if [ -n "$candidate_version" ] && semver_gte "$candidate_version" "$required_min_version"; then
      export PATH="$bin:$PATH"
      hash -r
      echo "ℹ️ Frontend Node runtime: v${candidate_version} ($bin)"
      return 0
    fi
  done

  echo "❌ Frontend requires Node >= ${required_min_version}, current=${current_node_version:-not found}" >&2
  echo "   Install node@22 (recommended) or node@20.19+" >&2
  return 1
}

# -------------------------------------------------------------------
# Frontend Bootstrap
# -------------------------------------------------------------------
resolve_js_manager() {
  case "$JS_MANAGER" in
    yarn)
      command -v yarn >/dev/null 2>&1 || { echo "❌ yarn not found" >&2; return 1; }
      EFFECTIVE_JS_MANAGER="yarn"
      ;;
    npm)
      command -v npm >/dev/null 2>&1 || { echo "❌ npm not found" >&2; return 1; }
      EFFECTIVE_JS_MANAGER="npm"
      ;;
    auto)
      if [ -f "$CLIENT_DIR/yarn.lock" ] && command -v yarn >/dev/null 2>&1; then
        EFFECTIVE_JS_MANAGER="yarn"
      elif command -v npm >/dev/null 2>&1; then
        EFFECTIVE_JS_MANAGER="npm"
      elif command -v yarn >/dev/null 2>&1; then
        EFFECTIVE_JS_MANAGER="yarn"
      else
        echo "❌ npm/yarn not found" >&2
        return 1
      fi
      ;;
    *)
      echo "❌ Unsupported JS_MANAGER: $JS_MANAGER (use: auto|yarn|npm)" >&2
      return 1
      ;;
  esac
}

build_frontend_fingerprint() {
  {
    echo "manager=${EFFECTIVE_JS_MANAGER}"
    [ -f "$CLIENT_DIR/package.json" ] && cat "$CLIENT_DIR/package.json"
    [ -f "$CLIENT_DIR/yarn.lock" ] && cat "$CLIENT_DIR/yarn.lock"
    [ -f "$CLIENT_DIR/package-lock.json" ] && cat "$CLIENT_DIR/package-lock.json"
    true
  } | shasum | awk '{print $1}'
}

# -------------------------------------------------------------------
# Primary Commands
# -------------------------------------------------------------------
bootstrap_frontend() {
  resolve_frontend_node_runtime
  resolve_js_manager

  [ -f "$CLIENT_DIR/package.json" ] || { echo "❌ client/package.json not found" >&2; return 1; }

  local current previous
  current="$(build_frontend_fingerprint)"
  previous="$(cat "$FRONTEND_BOOTSTRAP_STATE" 2>/dev/null || true)"

  if [ "${FORCE_BOOTSTRAP_FRONTEND:-0}" = "1" ] || [ "$current" != "$previous" ] || [ ! -d "$CLIENT_DIR/node_modules" ]; then
    echo "📦 Bootstrapping frontend deps (${EFFECTIVE_JS_MANAGER})..."
    if [ "$EFFECTIVE_JS_MANAGER" = "yarn" ]; then
      (cd "$CLIENT_DIR" && yarn install) || return 1
    else
      (cd "$CLIENT_DIR" && npm install) || return 1
    fi
    echo "$current" > "$FRONTEND_BOOTSTRAP_STATE"
    echo "✅ Frontend bootstrap complete."
  else
    echo "✅ Frontend environment is up to date."
  fi
}

run_client() {
  bootstrap_frontend
  echo "🚀 Starting frontend (${EFFECTIVE_JS_MANAGER})..."
  if [ "$EFFECTIVE_JS_MANAGER" = "yarn" ]; then
    (cd "$CLIENT_DIR" && yarn dev)
  else
    (cd "$CLIENT_DIR" && npm run dev)
  fi
}

run_deploy() {
  bootstrap_frontend
  if ! command -v "$VERCEL_BIN" >/dev/null 2>&1; then
    echo "❌ vercel CLI not found. Install with: npm i -g vercel" >&2
    return 1
  fi
  echo "🚀 Deploying frontend (Vercel prod)..."
  (cd "$VERCEL_PROJECT_DIR" && "$VERCEL_BIN" --prod --yes)
}

# -------------------------------------------------------------------
# Legacy Delegation
# -------------------------------------------------------------------
delegate_legacy() {
  local legacy="$PROJECT_ROOT/scripts/run-legacy.sh"
  if [ ! -x "$legacy" ]; then
    echo "❌ Legacy runner missing: $legacy" >&2
    return 1
  fi
  echo "↪️ Delegating to legacy runner: $legacy $*"
  exec "$legacy" "$@"
}

# -------------------------------------------------------------------
# Command Dispatch
# -------------------------------------------------------------------
case "$COMMAND" in
  client|front|dev)
    run_client
    ;;
  deploy)
    run_deploy
    ;;
  legacy)
    delegate_legacy "$@"
    ;;
  server|api|public|public-status|public-stop|tunnel|tunnel-stop|clean|test)
    delegate_legacy "$COMMAND" "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "❌ Unknown command: $COMMAND" >&2
    usage
    exit 1
    ;;
esac
