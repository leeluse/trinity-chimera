{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Skill(update-config)"
    ],
    "tools": "dontAsk",
    "commands": "dontAsk",
    "fileOperations": "dontAsk"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": []
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": []
      }
    ]
  },
  "outputStyle": "detailed",
  "customInstructions": "한국어로 응답하세요. 코드를 작성할 때 주석은 필요한 경우에만 추가하세요.",
  "shortcuts": {
    "/w": "/what",
    "/h": "/help",
    "/c": "/clear",
    "/m": "/memory",
    "/s": "/status"
  },
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    }
  }
}
